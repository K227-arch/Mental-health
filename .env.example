# Copy this file to .env.local and fill in your values

# InsForge Backend
NEXT_PUBLIC_INSFORGE_URL=https://your-app.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=anon_your_anon_key_here
INSFORGE_API_KEY=ik_your_api_key_here

# HuggingFace Inference API (get keys from https://huggingface.co/settings/tokens)
HF_READ_API_KEY=hf_your_read_key_here
HF_WRITE_API_KEY=hf_your_write_key_here

# Optional — only needed for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
